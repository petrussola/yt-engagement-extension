{
  "manifest_version": 3,
  "name": "YouTube Engage-o-meter",
  "version": "0.1.0",
  "description": "Highlights YouTube videos with unusually low visible engagement for their view count.",
  "action": {
    "default_title": "YouTube Engage-o-meter",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-engage-o-meter@petrussola",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
